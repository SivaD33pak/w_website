# Copy to .env.local and adjust as needed.
#
# Base URL of the FastAPI backend. Used by Next rewrites for all /api endpoints.
# Defaults to http://localhost:8000 in local dev if unset.
BACKEND_API_URL=http://localhost:8000

# Optional public override for direct browser-to-backend calls. Leave blank to
# use same-origin /api requests through the Next rewrite above.
NEXT_PUBLIC_API_URL=

# Source events & gallery from the backend API instead of local data.
# - false (default): sections render from lib/wedding-content.ts
# - true           : sections fetch from the API and merge with local metadata
NEXT_PUBLIC_USE_API_DATA=false
