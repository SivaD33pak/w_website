# Copy to .env and adjust as needed.
#
# Comma-separated list of allowed CORS origins (the frontend URLs that may
# call this API). Defaults to http://localhost:3000 if unset.
# In production, set this to your Vercel origin(s), e.g.
#   CORS_ORIGINS=https://sushmi-nijin.vercel.app
CORS_ORIGINS=http://localhost:3000

# Google Sheets credentials — the entire JSON content of the service-account
# key file downloaded from Google Cloud Console.
# Paste as a single-line JSON string.
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Google Sheet ID — the long string between /d/ and /edit in the sheet URL.
# Example: https://docs.google.com/spreadsheets/d/1aBcDeFgHiJkLmNoPqRs/edit
#                                                     ^^^^^^^^^^^^^^^^^^ this is the ID
GOOGLE_SHEET_ID=your-sheet-id-here
